{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ruankaodaren-ai-learning-generation-request",
  "title": "Ruankaodaren Phase 7.0 AI Learning Generation Request",
  "type": "object",
  "required": [
    "manifest_version",
    "manifest_type",
    "phase",
    "artifact_type",
    "status",
    "created_for_phase",
    "created_at",
    "request_status",
    "request_mode",
    "batch_id",
    "upstream_phase",
    "upstream_manifest",
    "upstream_artifact_type",
    "upstream_closure_status",
    "upstream_closure_result",
    "crawler_allowed",
    "renderer_allowed",
    "recovery_allowed",
    "web_requests_allowed",
    "source_layer_modification_allowed",
    "ai_learning_content_generation_allowed",
    "ai_learning_request_creation_allowed",
    "phase7_1_entry_allowed",
    "requested_future_outputs",
    "actual_generated_outputs",
    "scope",
    "risk",
    "closure",
    "next_phase_recommendation",
    "rollback_condition",
    "audit_condition",
    "validation_expectations"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_version": { "const": "phase7.0" },
    "manifest_type": { "const": "ai_learning_generation_request" },
    "phase": { "const": "7.0" },
    "artifact_type": { "const": "ai_learning_generation_request" },
    "status": { "const": "ai_learning_generation_request_created" },
    "created_for_phase": { "const": "7.0" },
    "created_at": { "type": "string", "format": "date-time" },
    "request_status": { "const": "requested" },
    "request_mode": { "const": "request_only" },
    "batch_id": { "const": "phase6_1_batch_001" },
    "upstream_phase": { "const": "6.22" },
    "upstream_manifest": { "const": "phase6_22_formal_run_review_and_closure_report.json" },
    "upstream_artifact_type": { "const": "formal_run_review_and_closure_report" },
    "upstream_closure_status": { "const": "closed" },
    "upstream_closure_result": { "const": "pass" },
    "crawler_allowed": { "const": false },
    "renderer_allowed": { "const": false },
    "recovery_allowed": { "const": false },
    "web_requests_allowed": { "const": false },
    "source_layer_modification_allowed": { "const": false },
    "ai_learning_content_generation_allowed": { "const": false },
    "ai_learning_request_creation_allowed": { "const": true },
    "phase7_1_entry_allowed": { "const": false },
    "requested_future_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "learning_objectives",
          "knowledge_units",
          "exam_oriented_explanations",
          "practice_questions",
          "answer_rationales",
          "misconception_warnings",
          "review_checklist",
          "source_traceability_map"
        ]
      },
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true
    },
    "actual_generated_outputs": {
      "type": "array",
      "maxItems": 0
    },
    "scope": {
      "type": "object",
      "required": [
        "allowed_source_basis",
        "unapproved_sources_allowed",
        "external_sources_allowed",
        "source_expansion_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "allowed_source_basis": { "const": "closed_pass_phase6_1_batch_001_only" },
        "unapproved_sources_allowed": { "const": false },
        "external_sources_allowed": { "const": false },
        "source_expansion_allowed": { "const": false }
      }
    },
    "risk": {
      "type": "object",
      "required": ["risk_level", "risk_reason"],
      "additionalProperties": false,
      "properties": {
        "risk_level": { "const": "low" },
        "risk_reason": { "type": "string" }
      }
    },
    "closure": {
      "type": "object",
      "required": ["phase7_0_status", "phase7_0_result"],
      "additionalProperties": false,
      "properties": {
        "phase7_0_status": { "const": "complete" },
        "phase7_0_result": { "const": "pass" }
      }
    },
    "next_phase_recommendation": {
      "type": "object",
      "required": [
        "next_recommended_phase",
        "phase7_1_entry_allowed",
        "phase7_1_entry_requires_approval",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "next_recommended_phase": { "const": "phase7.1_ai_learning_generation_execution" },
        "phase7_1_entry_allowed": { "const": false },
        "phase7_1_entry_requires_approval": { "const": true },
        "notes": { "type": "string" }
      }
    },
    "rollback_condition": {
      "type": "object",
      "required": ["phase7_0_rollback_needed", "reason"],
      "additionalProperties": false,
      "properties": {
        "phase7_0_rollback_needed": { "const": false },
        "reason": { "type": "string" }
      }
    },
    "audit_condition": {
      "type": "object",
      "required": [
        "upstream_phase_chain_complete",
        "upstream_closure_status",
        "upstream_closure_result",
        "request_mode",
        "actual_generated_outputs_empty",
        "validation_commands",
        "commit_scope"
      ],
      "additionalProperties": false,
      "properties": {
        "upstream_phase_chain_complete": { "const": true },
        "upstream_closure_status": { "const": "closed" },
        "upstream_closure_result": { "const": "pass" },
        "request_mode": { "const": "request_only" },
        "actual_generated_outputs_empty": { "const": true },
        "validation_commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "commit_scope": { "type": "string" }
      }
    },
    "validation_expectations": {
      "type": "object",
      "required": [
        "schema_validation",
        "invariant_checks",
        "phase_must_be",
        "artifact_type_must_be",
        "request_mode_must_be",
        "batch_id_must_be",
        "upstream_phase_must_be",
        "upstream_closure_status_must_be",
        "upstream_closure_result_must_be",
        "ai_learning_content_generation_allowed_must_be",
        "ai_learning_request_creation_allowed_must_be",
        "phase7_1_entry_allowed_must_be",
        "actual_generated_outputs_must_be_empty",
        "requested_future_outputs_count_must_be",
        "risk_level_must_be",
        "closure_status_must_be",
        "closure_result_must_be"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_validation": { "const": "must_pass" },
        "invariant_checks": { "const": "must_pass" },
        "phase_must_be": { "const": "7.0" },
        "artifact_type_must_be": { "const": "ai_learning_generation_request" },
        "request_mode_must_be": { "const": "request_only" },
        "batch_id_must_be": { "const": "phase6_1_batch_001" },
        "upstream_phase_must_be": { "const": "6.22" },
        "upstream_closure_status_must_be": { "const": "closed" },
        "upstream_closure_result_must_be": { "const": "pass" },
        "ai_learning_content_generation_allowed_must_be": { "const": false },
        "ai_learning_request_creation_allowed_must_be": { "const": true },
        "phase7_1_entry_allowed_must_be": { "const": false },
        "actual_generated_outputs_must_be_empty": { "const": true },
        "requested_future_outputs_count_must_be": { "const": 8 },
        "risk_level_must_be": { "const": "low" },
        "closure_status_must_be": { "const": "complete" },
        "closure_result_must_be": { "const": "pass" }
      }
    }
  }
}
