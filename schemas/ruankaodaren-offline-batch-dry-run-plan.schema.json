{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ruankaodaren-offline-batch-dry-run-plan",
  "title": "Ruankaodaren Phase 6.15 Offline Batch Dry-Run Plan",
  "type": "object",
  "required": [
    "manifest_version",
    "manifest_type",
    "status",
    "created_for_phase",
    "inherits_from_phase",
    "created_at",
    "scope",
    "plan_status",
    "dry_run_status",
    "dry_run_executed",
    "batch_run_executed",
    "run_command_approved",
    "command_status",
    "command_is_executable_now",
    "command_has_been_executed",
    "run_mode",
    "batch_id",
    "approved_items",
    "execution_authorization_status",
    "operational_mode_approval_status",
    "plan_metadata",
    "dry_run_scope",
    "dry_run_intent",
    "planned_dry_run_command",
    "phase_gates",
    "operational_gate_decisions",
    "planned_dry_run_assertions",
    "allowed_future_outputs",
    "forbidden_phase6_15_artifacts",
    "no_go_confirmation",
    "operational_assertions",
    "rollback_condition",
    "audit_condition",
    "phase_progression_history",
    "validation_expectations"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_version": { "const": "phase6.15" },
    "manifest_type": { "const": "offline_batch_dry_run_plan" },
    "status": { "const": "offline_batch_dry_run_plan_created" },
    "created_for_phase": { "const": "6.15" },
    "inherits_from_phase": {
      "type": "array",
      "items": { "type": "string", "enum": ["6.0", "6.1", "6.2", "6.3", "6.4", "6.5", "6.6", "6.7", "6.8", "6.9", "6.10", "6.11", "6.12", "6.13", "6.14"] },
      "minItems": 15,
      "maxItems": 15
    },
    "created_at": { "type": "string", "format": "date-time" },
    "scope": {
      "type": "object",
      "required": ["allowed", "forbidden"],
      "additionalProperties": false,
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" } },
        "forbidden": { "type": "array", "items": { "type": "string" } }
      }
    },
    "plan_status": { "const": "planned_not_executed" },
    "dry_run_status": { "const": "not_started" },
    "dry_run_executed": { "const": false },
    "batch_run_executed": { "const": false },
    "run_command_approved": { "const": true },
    "command_status": { "const": "approved" },
    "command_is_executable_now": { "const": true },
    "command_has_been_executed": { "const": false },
    "run_mode": { "const": "offline_existing_source_packet_only" },
    "batch_id": { "const": "phase6_1_batch_001" },
    "approved_items": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 1
    },
    "execution_authorization_status": { "const": "execution_approved" },
    "operational_mode_approval_status": { "const": "operational_mode_approved" },
    "plan_metadata": {
      "type": "object",
      "required": [
        "plan_id",
        "plan_type",
        "plan_phase",
        "plan_timestamp",
        "prior_decision_phase",
        "prior_decision_manifest",
        "prior_decision_status",
        "referencing_approval_phase",
        "referencing_decision_phase",
        "referencing_plan_phase",
        "plan_scope"
      ],
      "additionalProperties": false,
      "properties": {
        "plan_id": { "type": "string" },
        "plan_type": { "const": "offline_batch_dry_run_plan" },
        "plan_phase": { "const": "6.15" },
        "plan_timestamp": { "type": "string", "format": "date-time" },
        "prior_decision_phase": { "const": "6.14" },
        "prior_decision_manifest": { "type": "string" },
        "prior_decision_status": { "const": "offline_batch_run_command_approval_decision_recorded" },
        "referencing_approval_phase": { "const": "6.14" },
        "referencing_decision_phase": { "const": "6.11" },
        "referencing_plan_phase": { "const": "6.12" },
        "plan_scope": { "const": "offline_batch_dry_run_plan_only" }
      }
    },
    "dry_run_scope": {
      "type": "object",
      "required": [
        "eligible_items",
        "deferred_items",
        "quarantined_items",
        "item_count",
        "source_layer_mutation_allowed",
        "output_artifact_creation_allowed",
        "constraints"
      ],
      "additionalProperties": false,
      "properties": {
        "eligible_items": { "type": "array", "items": { "type": "string" } },
        "deferred_items": { "type": "array", "items": { "type": "string" } },
        "quarantined_items": { "type": "array", "items": { "type": "string" } },
        "item_count": { "type": "number" },
        "source_layer_mutation_allowed": { "const": false },
        "output_artifact_creation_allowed": { "const": false },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "dry_run_intent": {
      "type": "object",
      "required": ["description", "verification_targets"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "verification_targets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "planned_dry_run_command": {
      "type": "object",
      "required": [
        "command_id",
        "command_type",
        "command_status",
        "command_is_executable_now",
        "command_has_been_executed",
        "command_text_placeholder",
        "command_is_placeholder_only",
        "command_not_in_package_json",
        "command_arguments",
        "command_constraints"
      ],
      "additionalProperties": false,
      "properties": {
        "command_id": { "type": "string" },
        "command_type": { "const": "offline_batch_dry_run" },
        "command_status": { "const": "planned" },
        "command_is_executable_now": { "const": false },
        "command_has_been_executed": { "const": false },
        "command_text_placeholder": { "type": "string" },
        "command_is_placeholder_only": { "const": true },
        "command_not_in_package_json": { "const": true },
        "command_arguments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["argument", "value", "description"],
            "additionalProperties": false,
            "properties": {
              "argument": { "type": "string" },
              "value": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "minItems": 3,
          "maxItems": 3
        },
        "command_constraints": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 5,
          "maxItems": 5
        }
      }
    },
    "phase_gates": {
      "type": "object",
      "required": [
        "phase6_1_entry_allowed",
        "activation_allowed",
        "batch_executable",
        "execution_allowed",
        "crawler_allowed",
        "renderer_allowed",
        "recovery_allowed",
        "web_requests_allowed",
        "ai_learning_generation_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "phase6_1_entry_allowed": { "const": true },
        "activation_allowed": { "const": true },
        "batch_executable": { "const": true },
        "execution_allowed": { "const": true },
        "crawler_allowed": { "const": false },
        "renderer_allowed": { "const": false },
        "recovery_allowed": { "const": false },
        "web_requests_allowed": { "const": false },
        "ai_learning_generation_allowed": { "const": false }
      }
    },
    "operational_gate_decisions": {
      "type": "object",
      "required": [
        "crawler_gate_decision",
        "renderer_gate_decision",
        "recovery_gate_decision",
        "web_requests_gate_decision",
        "ai_learning_generation_gate_decision",
        "constraint"
      ],
      "additionalProperties": false,
      "properties": {
        "crawler_gate_decision": { "const": "not_required" },
        "renderer_gate_decision": { "const": "not_required" },
        "recovery_gate_decision": { "const": "not_required" },
        "web_requests_gate_decision": { "const": "not_required" },
        "ai_learning_generation_gate_decision": { "const": "not_allowed" },
        "constraint": { "type": "string" }
      }
    },
    "planned_dry_run_assertions": {
      "type": "object",
      "required": [
        "prior_phase_chain_complete",
        "run_command_approved",
        "command_has_not_been_executed",
        "dry_run_has_not_been_executed",
        "batch_run_has_not_been_executed",
        "operational_gates_remain_closed",
        "approved_items_equals_1_3",
        "item_13_3_excluded",
        "item_9_1_deferred",
        "no_forbidden_input_used",
        "no_forbidden_output_produced"
      ],
      "additionalProperties": false,
      "properties": {
        "prior_phase_chain_complete": { "const": true },
        "run_command_approved": { "const": true },
        "command_has_not_been_executed": { "const": true },
        "dry_run_has_not_been_executed": { "const": true },
        "batch_run_has_not_been_executed": { "const": true },
        "operational_gates_remain_closed": { "const": true },
        "approved_items_equals_1_3": { "const": true },
        "item_13_3_excluded": { "const": true },
        "item_9_1_deferred": { "const": true },
        "no_forbidden_input_used": { "const": true },
        "no_forbidden_output_produced": { "const": true }
      }
    },
    "allowed_future_outputs": {
      "type": "object",
      "required": ["description", "artifacts"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "purpose", "created_when", "status"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "purpose": { "type": "string" },
              "created_when": { "type": "string" },
              "status": { "const": "planned" }
            }
          },
          "minItems": 4,
          "maxItems": 4
        }
      }
    },
    "forbidden_phase6_15_artifacts": {
      "type": "object",
      "required": ["description", "artifacts"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 14,
          "maxItems": 14
        }
      }
    },
    "no_go_confirmation": {
      "type": "object",
      "required": [
        "no_dry_run_execution_occurs",
        "no_batch_execution_occurs",
        "no_crawler_runs",
        "no_renderer_runs",
        "no_recovery_runs",
        "no_web_requests_made",
        "no_source_layer_modified",
        "no_ai_learning_generated",
        "no_assets_captured",
        "no_raw_snapshots_created",
        "no_intermediate_json_created",
        "no_package_script_added_for_dry_run",
        "crawler_allowed_remains_false",
        "renderer_allowed_remains_false",
        "recovery_allowed_remains_false",
        "web_requests_allowed_remains_false",
        "ai_learning_generation_allowed_remains_false",
        "no_dry_run_record_created",
        "no_dry_run_result_created"
      ],
      "additionalProperties": false,
      "properties": {
        "no_dry_run_execution_occurs": { "const": true },
        "no_batch_execution_occurs": { "const": true },
        "no_crawler_runs": { "const": true },
        "no_renderer_runs": { "const": true },
        "no_recovery_runs": { "const": true },
        "no_web_requests_made": { "const": true },
        "no_source_layer_modified": { "const": true },
        "no_ai_learning_generated": { "const": true },
        "no_assets_captured": { "const": true },
        "no_raw_snapshots_created": { "const": true },
        "no_intermediate_json_created": { "const": true },
        "no_package_script_added_for_dry_run": { "const": true },
        "crawler_allowed_remains_false": { "const": true },
        "renderer_allowed_remains_false": { "const": true },
        "recovery_allowed_remains_false": { "const": true },
        "web_requests_allowed_remains_false": { "const": true },
        "ai_learning_generation_allowed_remains_false": { "const": true },
        "no_dry_run_record_created": { "const": true },
        "no_dry_run_result_created": { "const": true }
      }
    },
    "operational_assertions": {
      "type": "object",
      "required": [
        "dry_run_execution_claimed",
        "batch_execution_claimed",
        "crawler_output_claimed",
        "renderer_output_claimed",
        "recovery_output_claimed",
        "ai_learning_generation_claimed",
        "source_layer_mutation_declared",
        "web_requests_declared",
        "raw_snapshots_created",
        "intermediate_json_created",
        "assets_captured"
      ],
      "additionalProperties": false,
      "properties": {
        "dry_run_execution_claimed": { "const": false },
        "batch_execution_claimed": { "const": false },
        "crawler_output_claimed": { "const": false },
        "renderer_output_claimed": { "const": false },
        "recovery_output_claimed": { "const": false },
        "ai_learning_generation_claimed": { "const": false },
        "source_layer_mutation_declared": { "const": false },
        "web_requests_declared": { "const": false },
        "raw_snapshots_created": { "const": false },
        "intermediate_json_created": { "const": false },
        "assets_captured": { "const": false }
      }
    },
    "rollback_condition": {
      "type": "object",
      "required": ["phase6_15_rollback_needed", "reason", "future_dry_run_rollback_requirements"],
      "additionalProperties": false,
      "properties": {
        "phase6_15_rollback_needed": { "const": false },
        "reason": { "type": "string" },
        "future_dry_run_rollback_requirements": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3,
          "maxItems": 3
        }
      }
    },
    "audit_condition": {
      "type": "object",
      "required": [
        "prior_phase_chain",
        "current_command_approval_status",
        "current_dry_run_status",
        "current_dry_run_executed",
        "current_batch_run_executed",
        "current_plan_status",
        "current_operational_gates",
        "no_go_confirmation",
        "validation_commands",
        "commit_scope"
      ],
      "additionalProperties": false,
      "properties": {
        "prior_phase_chain": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 15,
          "maxItems": 15
        },
        "current_command_approval_status": { "const": "approved" },
        "current_dry_run_status": { "const": "not_started" },
        "current_dry_run_executed": { "const": false },
        "current_batch_run_executed": { "const": false },
        "current_plan_status": { "const": "planned_not_executed" },
        "current_operational_gates": {
          "type": "object",
          "required": [
            "phase6_1_entry_allowed",
            "activation_allowed",
            "batch_executable",
            "execution_allowed",
            "crawler_allowed",
            "renderer_allowed",
            "recovery_allowed",
            "web_requests_allowed",
            "ai_learning_generation_allowed"
          ],
          "additionalProperties": false,
          "properties": {
            "phase6_1_entry_allowed": { "const": true },
            "activation_allowed": { "const": true },
            "batch_executable": { "const": true },
            "execution_allowed": { "const": true },
            "crawler_allowed": { "const": false },
            "renderer_allowed": { "const": false },
            "recovery_allowed": { "const": false },
            "web_requests_allowed": { "const": false },
            "ai_learning_generation_allowed": { "const": false }
          }
        },
        "no_go_confirmation": { "const": true },
        "validation_commands": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3,
          "maxItems": 3
        },
        "commit_scope": { "type": "string" }
      }
    },
    "phase_progression_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "outcome"],
        "additionalProperties": false,
        "properties": {
          "phase": { "type": "string" },
          "outcome": { "type": "string" }
        }
      },
      "minItems": 16,
      "maxItems": 16
    },
    "validation_expectations": {
      "type": "object",
      "required": [
        "schema_validation",
        "invariant_checks",
        "plan_status_must_be",
        "dry_run_status_must_be",
        "dry_run_executed_must_be",
        "batch_run_executed_must_be",
        "run_command_approved_must_be",
        "command_status_must_be",
        "command_is_executable_now_must_be",
        "command_has_been_executed_must_be",
        "operational_assertions_all_false",
        "no_go_confirmations_all_true",
        "item_constraints_satisfied",
        "future_outputs_planned_only",
        "forbidden_artifacts_explicitly_listed",
        "operational_gate_decisions_all_not_required_or_not_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_validation": { "const": "must_pass" },
        "invariant_checks": { "const": "must_pass" },
        "plan_status_must_be": { "const": "planned_not_executed" },
        "dry_run_status_must_be": { "const": "not_started" },
        "dry_run_executed_must_be": { "const": false },
        "batch_run_executed_must_be": { "const": false },
        "run_command_approved_must_be": { "const": true },
        "command_status_must_be": { "const": "approved" },
        "command_is_executable_now_must_be": { "const": true },
        "command_has_been_executed_must_be": { "const": false },
        "operational_assertions_all_false": { "const": true },
        "no_go_confirmations_all_true": { "const": true },
        "item_constraints_satisfied": { "const": true },
        "future_outputs_planned_only": { "const": true },
        "forbidden_artifacts_explicitly_listed": { "const": true },
        "operational_gate_decisions_all_not_required_or_not_allowed": { "const": true }
      }
    }
  }
}
