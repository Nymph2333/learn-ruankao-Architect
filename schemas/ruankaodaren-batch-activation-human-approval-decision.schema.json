{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ruankaodaren-batch-activation-human-approval-decision",
  "title": "Ruankaodaren Phase 6.5 Batch Activation Human Approval Decision",
  "type": "object",
  "required": [
    "manifest_version",
    "manifest_type",
    "status",
    "created_for_phase",
    "inherits_from_phase",
    "created_at",
    "scope",
    "phase_gates",
    "decision_metadata",
    "batch_summary",
    "phase_progression_history",
    "gate_state_after_decision",
    "item_constraints",
    "operational_assertions",
    "validation_expectations",
    "final_decision"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_version": { "const": "phase6.5" },
    "manifest_type": { "const": "batch_activation_human_approval_decision" },
    "status": { "const": "activation_approved" },
    "created_for_phase": { "const": "6.5" },
    "inherits_from_phase": {
      "type": "array",
      "items": { "type": "string", "enum": ["6.0", "6.1", "6.2", "6.3", "6.4"] },
      "minItems": 5,
      "maxItems": 5
    },
    "created_at": { "type": "string", "format": "date-time" },
    "scope": {
      "type": "object",
      "required": ["allowed", "forbidden"],
      "additionalProperties": false,
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" } },
        "forbidden": { "type": "array", "items": { "type": "string" } }
      }
    },
    "phase_gates": {
      "type": "object",
      "required": [
        "phase6_1_entry_allowed",
        "activation_allowed",
        "batch_executable",
        "execution_allowed",
        "crawler_allowed",
        "renderer_allowed",
        "recovery_allowed",
        "web_requests_allowed",
        "ai_learning_generation_allowed",
        "approval_granted"
      ],
      "additionalProperties": false,
      "properties": {
        "phase6_1_entry_allowed": { "const": true },
        "activation_allowed": { "const": true },
        "batch_executable": { "const": false },
        "execution_allowed": { "const": false },
        "crawler_allowed": { "const": false },
        "renderer_allowed": { "const": false },
        "recovery_allowed": { "const": false },
        "web_requests_allowed": { "const": false },
        "ai_learning_generation_allowed": { "const": false },
        "approval_granted": { "const": true }
      }
    },
    "decision_metadata": {
      "type": "object",
      "required": [
        "decision_id",
        "decision_type",
        "approval_status",
        "approved_decision",
        "approved_batch_id",
        "approved_items",
        "approval_scope",
        "execution_approval_status",
        "requires_execution_approval",
        "decision_timestamp"
      ],
      "additionalProperties": false,
      "properties": {
        "decision_id": { "type": "string" },
        "decision_type": { "const": "human_activation_approval" },
        "approval_status": { "const": "activation_approved" },
        "approved_decision": { "const": "approve_activation" },
        "approved_batch_id": { "const": "phase6_1_batch_001" },
        "approved_items": {
          "type": "array",
          "items": { "const": "1.3" },
          "minItems": 1,
          "maxItems": 1
        },
        "approval_scope": { "const": "activation_only" },
        "execution_approval_status": {
          "type": "string",
          "enum": ["not_requested", "explicitly_denied"]
        },
        "requires_execution_approval": { "const": true },
        "decision_timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "batch_summary": {
      "type": "object",
      "required": [
        "batch_id",
        "selected_items",
        "approved_items",
        "item_count",
        "readiness_status",
        "items",
        "deferred_items",
        "quarantined_items"
      ],
      "additionalProperties": false,
      "properties": {
        "batch_id": { "const": "phase6_1_batch_001" },
        "selected_items": {
          "type": "array",
          "items": { "const": "1.3" },
          "minItems": 1,
          "maxItems": 1
        },
        "approved_items": {
          "type": "array",
          "items": { "const": "1.3" },
          "minItems": 1,
          "maxItems": 1
        },
        "item_count": { "const": 1 },
        "readiness_status": { "const": "activation_approved" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["item_id", "title", "status", "readiness", "risk_level"],
            "additionalProperties": false,
            "properties": {
              "item_id": { "type": "string" },
              "title": { "type": "string" },
              "status": { "type": "string" },
              "readiness": { "type": "string" },
              "risk_level": { "type": "string" }
            }
          }
        },
        "deferred_items": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "9.1" }
        },
        "quarantined_items": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "13.3" }
        }
      }
    },
    "phase_progression_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "outcome"],
        "additionalProperties": false,
        "properties": {
          "phase": { "type": "string" },
          "outcome": { "type": "string" }
        }
      },
      "minItems": 6,
      "maxItems": 6
    },
    "gate_state_after_decision": {
      "type": "object",
      "required": ["gates_opened", "gates_remaining_closed", "separation_note"],
      "additionalProperties": false,
      "properties": {
        "gates_opened": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gate", "previous", "current", "rationale"],
            "additionalProperties": false,
            "properties": {
              "gate": { "type": "string" },
              "previous": { "const": false },
              "current": { "const": true },
              "rationale": { "type": "string" }
            }
          }
        },
        "gates_remaining_closed": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gate", "value", "rationale"],
            "additionalProperties": false,
            "properties": {
              "gate": { "type": "string" },
              "value": { "const": false },
              "rationale": { "type": "string" }
            }
          }
        },
        "separation_note": { "type": "string" }
      }
    },
    "item_constraints": {
      "type": "object",
      "required": ["approved_items", "deferred_items", "quarantined_items", "constraints"],
      "additionalProperties": false,
      "properties": {
        "approved_items": {
          "type": "array",
          "items": { "const": "1.3" },
          "minItems": 1,
          "maxItems": 1
        },
        "deferred_items": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "9.1" }
        },
        "quarantined_items": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "13.3" }
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "operational_assertions": {
      "type": "object",
      "required": [
        "expansion_execution_claimed",
        "ai_learning_generation_claimed",
        "source_layer_mutation_declared",
        "web_requests_made",
        "assets_captured",
        "raw_snapshots_created",
        "intermediate_json_created"
      ],
      "additionalProperties": false,
      "properties": {
        "expansion_execution_claimed": { "const": false },
        "ai_learning_generation_claimed": { "const": false },
        "source_layer_mutation_declared": { "const": false },
        "web_requests_made": { "const": false },
        "assets_captured": { "const": false },
        "raw_snapshots_created": { "const": false },
        "intermediate_json_created": { "const": false }
      }
    },
    "validation_expectations": {
      "type": "object",
      "required": ["must_pass", "must_not_trigger"],
      "additionalProperties": false,
      "properties": {
        "must_pass": { "type": "array", "items": { "type": "string" } },
        "must_not_trigger": { "type": "array", "items": { "type": "string" } }
      }
    },
    "final_decision": {
      "type": "object",
      "required": [
        "decision_recorded",
        "approval_status",
        "approved_decision",
        "batch_id",
        "approved_items",
        "approval_scope",
        "phase6_1_entry_allowed",
        "activation_allowed",
        "batch_executable",
        "execution_allowed",
        "deferred_items",
        "quarantined_items"
      ],
      "additionalProperties": false,
      "properties": {
        "decision_recorded": { "const": true },
        "approval_status": { "const": "activation_approved" },
        "approved_decision": { "const": "approve_activation" },
        "batch_id": { "const": "phase6_1_batch_001" },
        "approved_items": {
          "type": "array",
          "items": { "const": "1.3" },
          "minItems": 1,
          "maxItems": 1
        },
        "approval_scope": { "const": "activation_only" },
        "phase6_1_entry_allowed": { "const": true },
        "activation_allowed": { "const": true },
        "batch_executable": { "const": false },
        "execution_allowed": { "const": false },
        "deferred_items": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "9.1" }
        },
        "quarantined_items": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "13.3" }
        }
      }
    }
  }
}
