{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ruankaodaren.example/schemas/ruankaodaren-ai-learning-generation-execution-plan.schema.json",
  "title": "Phase 7.2 AI Learning Generation Execution Plan",
  "description": "Schema for the Phase 7.2 AI learning generation execution plan manifest.",
  "type": "object",
  "required": [
    "manifest_version",
    "manifest_type",
    "phase",
    "artifact_type",
    "status",
    "created_for_phase",
    "created_at",
    "execution_plan_status",
    "execution_mode",
    "execution_status",
    "upstream_phase",
    "upstream_manifest",
    "upstream_artifact_type",
    "upstream_approval_status",
    "upstream_ai_learning_generation_approved",
    "batch_id",
    "crawler_allowed",
    "renderer_allowed",
    "recovery_allowed",
    "web_requests_allowed",
    "source_layer_modification_allowed",
    "ai_learning_content_generation_allowed",
    "ai_learning_request_creation_allowed",
    "phase7_2_entry_allowed",
    "phase7_3_entry_allowed",
    "planned_outputs",
    "actual_generated_outputs",
    "scope",
    "risk",
    "closure",
    "next_phase_recommendation",
    "rollback_condition",
    "audit_condition",
    "phase_progression_history",
    "validation_expectations"
  ],
  "properties": {
    "manifest_version": { "const": "phase7.2" },
    "manifest_type": { "const": "ai_learning_generation_execution_plan" },
    "phase": { "const": "7.2" },
    "artifact_type": { "const": "ai_learning_generation_execution_plan" },
    "status": { "const": "ai_learning_generation_execution_plan_created" },
    "created_for_phase": { "const": "7.2" },
    "created_at": { "type": "string", "format": "date-time" },
    "execution_plan_status": { "const": "planned" },
    "execution_mode": { "const": "offline_existing_source_packet_only" },
    "execution_status": { "const": "not_started" },
    "upstream_phase": { "const": "7.1" },
    "upstream_manifest": { "const": "phase7_1_ai_learning_generation_approval_gate.json" },
    "upstream_artifact_type": { "const": "ai_learning_generation_approval_gate" },
    "upstream_approval_status": { "const": "ai_learning_generation_approved" },
    "upstream_ai_learning_generation_approved": { "const": true },
    "batch_id": { "const": "phase6_1_batch_001" },
    "crawler_allowed": { "const": false },
    "renderer_allowed": { "const": false },
    "recovery_allowed": { "const": false },
    "web_requests_allowed": { "const": false },
    "source_layer_modification_allowed": { "const": false },
    "ai_learning_content_generation_allowed": { "const": true },
    "ai_learning_request_creation_allowed": { "const": true },
    "phase7_2_entry_allowed": { "const": true },
    "phase7_3_entry_allowed": { "const": false },
    "planned_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "learning_objectives",
              "knowledge_units",
              "exam_oriented_explanations",
              "practice_questions",
              "answer_rationales",
              "misconception_warnings",
              "review_checklist",
              "source_traceability_map"
            ]
          },
          "status": { "const": "planned" }
        },
        "additionalProperties": false
      },
      "minItems": 8,
      "maxItems": 8
    },
    "actual_generated_outputs": {
      "type": "array",
      "maxItems": 0
    },
    "scope": {
      "type": "object",
      "required": [
        "allowed",
        "forbidden",
        "allowed_source_basis",
        "unapproved_sources_allowed",
        "external_sources_allowed",
        "source_expansion_allowed",
        "generation_mode",
        "source_packet_boundary"
      ],
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "forbidden": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "allowed_source_basis": { "const": "closed_pass_phase6_1_batch_001_only" },
        "unapproved_sources_allowed": { "const": false },
        "external_sources_allowed": { "const": false },
        "source_expansion_allowed": { "const": false },
        "generation_mode": { "const": "offline_existing_source_packet_only" },
        "source_packet_boundary": { "const": "frozen_after_phase6_22_closure" }
      },
      "additionalProperties": false
    },
    "risk": {
      "type": "object",
      "required": ["risk_level", "risk_reason"],
      "properties": {
        "risk_level": { "const": "low" },
        "risk_reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "closure": {
      "type": "object",
      "required": ["phase7_2_status", "phase7_2_result"],
      "properties": {
        "phase7_2_status": { "const": "complete" },
        "phase7_2_result": { "const": "pass" }
      },
      "additionalProperties": false
    },
    "next_phase_recommendation": {
      "type": "object",
      "required": [
        "next_recommended_phase",
        "phase7_3_entry_allowed",
        "phase7_3_entry_requires_approval",
        "notes"
      ],
      "properties": {
        "next_recommended_phase": { "const": "phase7.3_ai_learning_generation_validation" },
        "phase7_3_entry_allowed": { "const": false },
        "phase7_3_entry_requires_approval": { "const": true },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "rollback_condition": {
      "type": "object",
      "required": ["phase7_2_rollback_needed", "reason", "future_rollback_requirements"],
      "properties": {
        "phase7_2_rollback_needed": { "const": false },
        "reason": { "type": "string" },
        "future_rollback_requirements": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      },
      "additionalProperties": false
    },
    "audit_condition": {
      "type": "object",
      "required": [
        "upstream_phase",
        "upstream_approval_status",
        "upstream_ai_learning_generation_approved",
        "current_execution_plan_status",
        "current_execution_status",
        "current_ai_learning_content_generation_allowed",
        "current_phase7_2_entry_allowed",
        "current_phase7_3_entry_allowed",
        "planned_output_count",
        "actual_generated_outputs_empty",
        "source_packet_boundary_frozen",
        "validation_commands",
        "commit_scope"
      ],
      "properties": {
        "upstream_phase": { "const": "7.1" },
        "upstream_approval_status": { "const": "ai_learning_generation_approved" },
        "upstream_ai_learning_generation_approved": { "const": true },
        "current_execution_plan_status": { "const": "planned" },
        "current_execution_status": { "const": "not_started" },
        "current_ai_learning_content_generation_allowed": { "const": true },
        "current_phase7_2_entry_allowed": { "const": true },
        "current_phase7_3_entry_allowed": { "const": false },
        "planned_output_count": { "const": 8 },
        "actual_generated_outputs_empty": { "const": true },
        "source_packet_boundary_frozen": { "const": true },
        "validation_commands": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "commit_scope": { "type": "string" }
      },
      "additionalProperties": false
    },
    "phase_progression_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "outcome"],
        "properties": {
          "phase": { "type": "string" },
          "outcome": { "type": "string" }
        },
        "additionalProperties": false
      },
      "minItems": 3,
      "maxItems": 3
    },
    "validation_expectations": {
      "type": "object",
      "required": [
        "schema_validation",
        "invariant_checks",
        "phase_must_be",
        "artifact_type_must_be",
        "execution_plan_status_must_be",
        "execution_mode_must_be",
        "execution_status_must_be",
        "upstream_phase_must_be",
        "upstream_approval_status_must_be",
        "upstream_ai_learning_generation_approved_must_be",
        "batch_id_must_be",
        "ai_learning_content_generation_allowed_must_be",
        "phase7_2_entry_allowed_must_be",
        "phase7_3_entry_allowed_must_be",
        "crawler_allowed_must_be",
        "renderer_allowed_must_be",
        "recovery_allowed_must_be",
        "web_requests_allowed_must_be",
        "source_layer_modification_allowed_must_be",
        "actual_generated_outputs_must_be_empty",
        "planned_output_count_must_be",
        "all_planned_outputs_status_must_be_planned",
        "risk_level_must_be",
        "closure_status_must_be",
        "closure_result_must_be"
      ],
      "properties": {
        "schema_validation": { "const": "must_pass" },
        "invariant_checks": { "const": "must_pass" },
        "phase_must_be": { "const": "7.2" },
        "artifact_type_must_be": { "const": "ai_learning_generation_execution_plan" },
        "execution_plan_status_must_be": { "const": "planned" },
        "execution_mode_must_be": { "const": "offline_existing_source_packet_only" },
        "execution_status_must_be": { "const": "not_started" },
        "upstream_phase_must_be": { "const": "7.1" },
        "upstream_approval_status_must_be": { "const": "ai_learning_generation_approved" },
        "upstream_ai_learning_generation_approved_must_be": { "const": true },
        "batch_id_must_be": { "const": "phase6_1_batch_001" },
        "ai_learning_content_generation_allowed_must_be": { "const": true },
        "phase7_2_entry_allowed_must_be": { "const": true },
        "phase7_3_entry_allowed_must_be": { "const": false },
        "crawler_allowed_must_be": { "const": false },
        "renderer_allowed_must_be": { "const": false },
        "recovery_allowed_must_be": { "const": false },
        "web_requests_allowed_must_be": { "const": false },
        "source_layer_modification_allowed_must_be": { "const": false },
        "actual_generated_outputs_must_be_empty": { "const": true },
        "planned_output_count_must_be": { "const": 8 },
        "all_planned_outputs_status_must_be_planned": { "const": true },
        "risk_level_must_be": { "const": "low" },
        "closure_status_must_be": { "const": "complete" },
        "closure_result_must_be": { "const": "pass" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
